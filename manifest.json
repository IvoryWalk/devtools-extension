{
  "manifest_version": 3,
  "name": "DevToolBox - 开发者工具箱",
  "version": "1.4.0",
  "description": "开发者常用工具集合：JSON格式化、编解码、时间戳转换、Cron解析、数据暂存",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DevToolBox 开发者工具箱"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
